# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram bot tokens (from @BotFather) ──────────────────────
# At minimum, set BOT_TOKEN_ORCHESTRATOR.
# Add more tokens to activate additional agents.
BOT_TOKEN_ORCHESTRATOR=
BOT_TOKEN_CODER=
BOT_TOKEN_QA=
BOT_TOKEN_DEVOPS=
BOT_TOKEN_RESEARCHER=
BOT_TOKEN_GROWTH=
BOT_TOKEN_CONTENT=
BOT_TOKEN_COMMUNITY=
BOT_TOKEN_LEADGEN=
BOT_TOKEN_OPS=

# ── Telegram group / topic IDs ─────────────────────────────────
# Your supergroup ID (negative number, e.g. -1001234567890)
TELEGRAM_GROUP_ID=

# Topic thread IDs for each team channel.
# Get these by sending a message in the topic and looking at
# message_thread_id in the Telegram API response, or by using
# the @getidsbot in your group.
TOPIC_BUILD=
TOPIC_RESEARCH=
TOPIC_SOCIAL=
TOPIC_LEADS=
TOPIC_OPS=

# ── Server ─────────────────────────────────────────────────────
# Public HTTPS URL of this server (required for Telegram webhooks).
# Leave blank for local development — falls back to long-polling.
# Example: https://your-app.up.railway.app
WEBHOOK_URL=

# Port (Railway sets this automatically; override for local dev)
PORT=3000
